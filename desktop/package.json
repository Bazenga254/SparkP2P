{
  "name": "sparkp2p",
  "version": "1.0.0",
  "description": "SparkP2P — Automated Binance P2P Trading",
  "main": "app.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win",
    "dev": "electron ."
  },
  "author": "SparkP2P",
  "license": "MIT",
  "devDependencies": {
    "electron": "^33.4.11",
    "electron-builder": "^26.8.1"
  },
  "build": {
    "appId": "com.sparkp2p.desktop",
    "productName": "SparkP2P",
    "win": {
      "target": "nsis",
      "icon": "icon.ico"
    },
    "nsis": {
      "oneClick": true,
      "allowToChangeInstallationDirectory": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.80.0",
    "chrome-remote-interface": "^0.34.0",
    "puppeteer-core": "^24.40.0"
  }
}
