{
  "name": "sparkp2p",
  "version": "1.1.69",
  "description": "SparkP2P Bot - Automated Binance P2P Trading",
  "main": "app.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron .",
    "build:win": "electron-builder --win",
    "build:mac": "electron-builder --mac",
    "build:linux": "electron-builder --linux",
    "publish": "electron-builder --win --publish always",
    "sim": "node sim/run-sim.js"
  },
  "author": "SparkP2P",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Bazenga254/SparkP2P.git"
  },
  "devDependencies": {
    "electron": "^33.4.11",
    "electron-builder": "^26.8.1"
  },
  "build": {
    "appId": "com.sparkp2p.desktop",
    "productName": "SparkP2P",
    "publish": [
      {
        "provider": "github",
        "owner": "Bazenga254",
        "repo": "SparkP2P"
      }
    ],
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "icon.png"
    },
    "mac": {
      "target": [
        "dmg"
      ],
      "icon": "icon.png"
    },
    "linux": {
      "target": [
        "AppImage"
      ],
      "icon": "icon.png"
    },
    "nsis": {
      "include": "build/installer.nsh",
      "oneClick": true,
      "allowToChangeInstallationDirectory": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "SparkP2P"
    },
    "files": [
      "app.js",
      "ai-scanner.js",
      "midscene.js",
      "preload.js",
      "lock.html",
      "icon.png",
      ".env",
      "node_modules/**/*"
    ]
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.87.0",
    "@midscene/web": "^1.7.3",
    "@playwright/test": "^1.59.1",
    "chrome-remote-interface": "^0.34.0",
    "electron-updater": "^6.8.3",
    "imapflow": "^1.3.1",
    "puppeteer-core": "^24.40.0",
    "qrcode": "^1.5.4",
    "speakeasy": "^2.0.0"
  }
}
