# Database
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/autop2p

# Redis
REDIS_URL=redis://localhost:6379/0

# JWT Auth
SECRET_KEY=your-secret-key-change-this
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# M-Pesa Daraja
MPESA_CONSUMER_KEY=your-consumer-key
MPESA_CONSUMER_SECRET=your-consumer-secret
MPESA_SHORTCODE=600XXX
MPESA_PASSKEY=your-passkey
MPESA_INITIATOR_NAME=your-initiator
MPESA_INITIATOR_PASSWORD=your-password
MPESA_SECURITY_CREDENTIAL=your-credential
MPESA_ENV=sandbox
MPESA_CALLBACK_BASE_URL=https://yourdomain.com

# Binance
BINANCE_DEFAULT_USER_AGENT=Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36

# Claude AI
ANTHROPIC_API_KEY=your-anthropic-key

# Platform
PLATFORM_FEE_PER_TRADE=15
PLATFORM_NAME=AutoP2P
