{
  "manifest_version": 3,
  "name": "SparkP2P - Binance P2P Automation",
  "description": "Connect your Binance P2P account to SparkP2P for automated trading",
  "version": "1.1.0",
  "permissions": ["cookies", "storage", "alarms", "webRequest", "scripting"],
  "host_permissions": ["https://*.binance.com/*"],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon16.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://*.binance.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  }
}
