{
  "manifest_version": 3,
  "name": "SparkP2P - Binance P2P Automation",
  "description": "Automated Binance P2P trading engine — polls orders, releases crypto, and syncs with SparkP2P",
  "version": "2.0.0",
  "permissions": ["cookies", "storage", "alarms", "tabs", "scripting", "notifications"],
  "host_permissions": [
    "https://*.binance.com/*",
    "https://sparkp2p.com/*",
    "https://mail.google.com/*",
    "https://accounts.google.com/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon16.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://*.binance.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  }
}
